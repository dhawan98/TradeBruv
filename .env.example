# TradeBruv local environment template.
# Copy this file to .env, fill only the keys you need, then restart the backend.
# Do not commit real secrets.

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
TRADEBRUV_LLM_API_KEY=
TRADEBRUV_LLM_MODEL=gpt-4o-mini
TRADEBRUV_LLM_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Market/news/social
SEC_USER_AGENT=
GDELT_ENABLED=true
FINANCIAL_MODELING_PREP_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
BENZINGA_API_KEY=
QUIVER_API_KEY=
CAPITOL_TRADES_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=
STOCKTWITS_ACCESS_TOKEN=

# Portfolio future
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# App
TRADEBRUV_ENV=local
TRADEBRUV_DATA_DIR=data
TRADEBRUV_OUTPUT_DIR=outputs
TRADEBRUV_ALLOW_LOCAL_ENV_EDITOR=false
